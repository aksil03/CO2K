// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Utilisateur {
  id       Int     @id @default(autoincrement())
  nom      String?
  prenom   String?
  email    String  @unique
  password String
}