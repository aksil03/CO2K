generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum TemplateRepas {
  PETIT_DEJ
  HOT
  SANDWICH
  WRAP
  SALADE
  COLLATION
}

enum MomentRepas {
  PETIT_DEJEUNER
  DEJEUNER
  COLLATION
  DINER
}

enum BacAliment {
  PROT_PORC
  PROT_VIANDE_ROUGE
  PROT_VOLAILLE
  PROT_BLANCHE_AUTRE
  PROT_P
  PROT_VEG
  RIZ
  PATE
  NOUILLE
  GNOCCHI
  CERE_REPAS
  SEMOU
  POTATO
  PAIN
  WRAP
  LEG
  LAITUE
  FROMAGE
  FRUIT_ENTIER
  FRUIT_PULPE
  CERE
  LAIT
  S_HOT_RED
  S_HOT_WHITE
  S_HOT_ASIA
  S_COLD
  VINAIGRETTE
  OLEAGINEUX
  BC
  GAL_RIZ
  HUILE
}

enum ObjectifPhysique {
  PRISE_DE_MASSE
  PERTE_DE_GRAS
  MAINTIEN
}

enum NiveauActivite {
  SEDENTAIRE
  LEGER
  MODERE
  INTENSE
  EXTREME
}

enum Genre {
  HOMME
  FEMME
}

enum RegimeAlimentaire {
  STANDARD
  SANS_PORC
  SANS_VIANDE
}

model Utilisateur {
  id            Int               @id @default(autoincrement())
  nom           String
  prenom        String
  email         String            @unique
  password      String
  age           Int
  poids         Float
  taille        Int
  genre         Genre             @default(HOMME)
  activite      NiveauActivite    @default(MODERE)
  objectif      ObjectifPhysique  @default(MAINTIEN)
  regime        RegimeAlimentaire @default(STANDARD)
  repas         Repas[]
  posts         Post[]
  likes         Like[]
  commentaires  Commentaire[]
  plannings     Planning[]
  badges        BadgeUtilisateur[]
  mesAbonnes     Follow[]          @relation("MesAbonnes")
  mesAbonnements Follow[]          @relation("MesAbonnements")
  createdAt     DateTime          @default(now())
}

model Follow {
  id_abonne      Int
  abonne         Utilisateur @relation("MesAbonnements", fields: [id_abonne], references: [id])
  id_star        Int
  star           Utilisateur @relation("MesAbonnes", fields: [id_star], references: [id])
  @@id([id_abonne, id_star])
}

model Post {
  id            Int         @id @default(autoincrement())
  titre         String     
  contenu       String     
  imageUrl      String?     
  createdAt     DateTime    @default(now())
  auteurId      Int
  auteur        Utilisateur @relation(fields: [auteurId], references: [id])
  repasId       Int?        @unique
  repas         Repas?      @relation(fields: [repasId], references: [id])
  planningId    Int?        
  planning      Planning?   @relation(fields: [planningId], references: [id])
  likes         Like[]
  commentaires  Commentaire[]
}

model Commentaire {
  id        Int      @id @default(autoincrement())
  texte     String
  createdAt DateTime @default(now())
  postId    Int
  post      Post     @relation(fields: [postId], references: [id])
  auteurId  Int
  auteur    Utilisateur @relation(fields: [auteurId], references: [id])
}

model Like {
  id        Int         @id @default(autoincrement())
  postId    Int
  post      Post        @relation(fields: [postId], references: [id])
  userId    Int
  user      Utilisateur @relation(fields: [userId], references: [id])
  @@unique([postId, userId])
}

model Badge {
  id          Int                @id @default(autoincrement())
  nom         String             
  description String
  icone       String             
  utilisateurs BadgeUtilisateur[]
}

model BadgeUtilisateur {
  id            Int         @id @default(autoincrement())
  obtenuLe      DateTime    @default(now())
  utilisateurId Int
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id])
  badgeId       Int
  badge         Badge       @relation(fields: [badgeId], references: [id])
  @@unique([utilisateurId, badgeId])
}

model Planning {
  id            Int         @id @default(autoincrement())
  nom           String      
  description   String?
  estPublic     Boolean     @default(false)
  auteurId      Int
  auteur        Utilisateur @relation(fields: [auteurId], references: [id])
  repas         Repas[]     
  posts         Post[]      
}

model Repas {
  id            Int            @id @default(autoincrement())
  dateConsom    DateTime       
  type          MomentRepas    @default(DEJEUNER)         
  nomTemplate   TemplateRepas 
  utilisateurId Int
  utilisateur   Utilisateur    @relation(fields: [utilisateurId], references: [id])
  planningId    Int?           
  planning      Planning?      @relation(fields: [planningId], references: [id])
  portions      Portion[]
  post          Post?          
}

model Portion {
  id        Int     @id @default(autoincrement())
  quantite  Float   
  repasId   Int
  repas     Repas   @relation(fields: [repasId], references: [id])
  alimentId Int
  aliment   Aliment @relation(fields: [alimentId], references: [id])
}

model Aliment {
  id            Int            @id @default(autoincrement())
  nom           String
  bac           BacAliment    
  co2           Float          
  cal           Int            
  prot          Float?         
  lip           Float?
  glu           Float?
  sucre         Float?
  sel           Float?
  gras_sat      Float?
  estSnack      Boolean        @default(false)
  estPlat       Boolean        @default(false) 
  estSandwich   Boolean        @default(false) 
  estVege       Boolean        @default(true) 
  portions      Portion[] 
}